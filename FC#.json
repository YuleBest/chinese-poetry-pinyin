[
  {
    "title": "方城 八",
    "author": "柳宗元",
    "content": [
      "蔡人歌矣，蔡風和矣。",
      "孰颣蔡初，胡甈爾居。",
      "式慕以康，爲愿有餘。",
      "是究是咨，皇德既舒。"
    ]
  },
  {
    "title": "方城 二",
    "author": "柳宗元",
    "content": [
      "愬拜即命，于皇之訓。",
      "既礪既攻，以後厥刃。",
      "王師嶷嶷，熊羆是式。",
      "銜勇韜力，日思予殛。"
    ]
  },
  {
    "title": "方城 九",
    "author": "柳宗元",
    "content": [
      "皇曰咨愬，裕乃父功。",
      "昔我文祖，惟西平是庸。",
      "內誨于家，外刑于邦。",
      "孰是蔡人，而不率從。"
    ]
  },
  {
    "title": "方城 六",
    "author": "柳宗元",
    "content": [
      "汝陰之茫，懸瓠之峨。",
      "是震是拔，大殲厥家。",
      "狡虜既縻，輸于國都。",
      "示之市人，即社行誅。"
    ]
  },
  {
    "title": "奉酬  其一",
    "author": "鄧忠臣",
    "content": [
      "秋闈深鎻覺愁多，賴有英遊玉趾過。",
      "日望高樓吟楚月，夢隨明月到湘羅。",
      "南宫曾看揮華藻，西館還來共笑歌。",
      "六稔飛光如過隙，人生誰奈老催何。"
    ]
  },
  {
    "title": "奉酬  其二",
    "author": "鄧忠臣",
    "content": [
      "試場未動文書靜，官舍相聯步履過。",
      "千丈蒼波爭倚薄，十圍便腹有森羅。",
      "登臨已結騷人恨，填委終翻勞者歌。",
      "後夜中秋佳月色，惟予不飲奈明何。"
    ]
  },
  {
    "title": "方城 七",
    "author": "柳宗元",
    "content": [
      "乃諭乃止，蔡有厚喜。",
      "完其室家，仰父俯子。",
      "汝水沄沄，既清而瀰。",
      "蔡人行歌，我步逶遲。"
    ]
  },
  {
    "title": "方城 三",
    "author": "柳宗元",
    "content": [
      "寇昏以狂，敢蹈愬疆。",
      "士獲厥心，大袒高驤。",
      "長戟酋矛，粲其綏章。",
      "右翦左屠，聿禽其良。"
    ]
  },
  {
    "title": "方城 四",
    "author": "柳宗元",
    "content": [
      "其良既宥，告以父母。",
      "恩柔于肌，卒貢爾有。",
      "維彼攸恃，乃偵乃誘維彼攸宅，乃發乃守。"
    ]
  },
  {
    "title": "方城 十",
    "author": "柳宗元",
    "content": [
      "蔡人率止，惟西平有子。",
      "西平有子，惟我有臣。",
      "疇允大邦，俾惠我人。",
      "于廟告功，以顧萬方。"
    ]
  },
  {
    "title": "方城 五",
    "author": "柳宗元",
    "content": [
      "其恃爰獲，我功我多。",
      "陰諜厥圖，以究爾訛。",
      "雨雪洋洋，大風來加。",
      "于燠其寒，于邇其遐。"
    ]
  },
  {
    "title": "方城 一",
    "author": "柳宗元",
    "content": [
      "方城臨臨，王卒峙之。",
      "匪徼匪競，皇有正命。",
      "皇命于愬，往舒余仁。",
      "踣彼艱頑，柔惠是馴。"
    ]
  }
]