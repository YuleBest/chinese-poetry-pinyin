[
  {
    "title": "郊廟歌辭 封泰山樂章 豫和 一",
    "author": "張說",
    "content": [
      "款泰壇，柴泰清。",
      "受天命，報天成。",
      "竦皇心，薦樂聲。",
      "志上達，歌下迎。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 豫和 二",
    "author": "張說",
    "content": [
      "億上帝，臨下庭。",
      "騎日月，陪列星。",
      "嘉祝信，大糦馨。",
      "澹神心，醉皇靈。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 豫和 三",
    "author": "張說",
    "content": [
      "相百辟，貢八荒。",
      "九歌敍，萬舞翔。",
      "肅振振，鏗皇皇。",
      "帝欣欣，福穰穰。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 豫和 四",
    "author": "張說",
    "content": [
      "高在上，道光明。",
      "物資始，德難名。",
      "承眷命，牧蒼生。",
      "寰宇謐，太階平。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 豫和 五",
    "author": "張說",
    "content": [
      "天道無親，至誠與鄰。",
      "山川遍禮，宮徵維新。",
      "玉帛非盛，聰明會真。",
      "正斯一德，通乎百神。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 豫和 六",
    "author": "張說",
    "content": [
      "饗帝饗親，維孝維聖。",
      "緝熙懿德，敷揚成命。",
      "華夷志同，笙鏞禮盛。",
      "明靈降止，感此誠敬。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 太和",
    "author": "張說",
    "content": [
      "孝敬中發，和容外彰。",
      "騰華照宇，如昇太陽。",
      "貞璧就奠，玄靈垂光。",
      "禮樂具舉，濟濟洋洋。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 肅和",
    "author": "張說",
    "content": [
      "奠祖配天，承天享帝。",
      "百靈咸秩，四海來祭。",
      "植我蒼璧，布我玄製。",
      "華日裴回，神煙容裔。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 雍和",
    "author": "張說",
    "content": [
      "俎豆有馥，粢盛潔豐。",
      "亦有和羹，既戒既平。",
      "鐘鼓管磬，肅唱和鳴。",
      "皇皇后祖，來我思成。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 壽和",
    "author": "張說",
    "content": [
      "烝烝我后，享獻惟夤。",
      "躬酌鬱鬯，跪奠明神。",
      "孝莫孝乎，配上帝親。",
      "敬莫敬乎，教天下臣。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 壽和",
    "author": "張說",
    "content": [
      "皇祖嚴配，配享皇天。",
      "皇皇降嘏，天子萬年。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 舒和",
    "author": "張說",
    "content": [
      "六鐘翕協六變成，八佾倘佯八風生。",
      "樂九[韶]兮人神感，美七德兮天地清。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 凱安",
    "author": "張說",
    "content": [
      "烈祖順三靈，文宗威四海。",
      "黃鉞誅羣盜，朱旗掃多罪。",
      "戢兵天下安，約法人心改。",
      "大哉干羽意，長見風雲在。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
  {
    "title": "郊廟歌辭 封泰山樂章 豫和",
    "author": "張說",
    "content": [
      "樂已終，[煙]燎上。",
      "懷靈惠，結皇想。",
      "歸風疾，迴風爽。",
      "百[福]來，衆神往。"
    ],
    "meta": {
      "tags": [
        "泰山"
      ]
    }
  },
