[
  {
    "title": "主簿年家丈游敬亭",
    "author": "董天吉",
    "content": [
      "逆旅頻爭席，郊原一振衣。",
      "聯鑣尋勝去，高蓋拂林飛。",
      "訪古江山是，懷人歲月非。",
      "禪林最安穩，棲鳥亦深依。"
    ]
  },
  {
    "title": "瞻彼南山詩  其一",
    "author": "司馬光",
    "content": [
      "瞻彼南山，有梌有棠。",
      "維葉牂牂，君子之燕。",
      "籩豆洋洋，鼎俎將將。",
      "百羞阜昌，上下樂康。",
      "邦家之光，君子萬年。",
      "撫有四荒，受祿無疆。"
    ]
  },
  {
    "title": "瞻彼南山詩  其二",
    "author": "司馬光",
    "content": [
      "瞻彼南山，有椐有栩。",
      "維葉湑湑，君子之燕。",
      "清酒有藇，壺樽有楚。",
      "酌言賜之，命之釂之。",
      "上下以序，君子萬年。",
      "永綏兆民，受天之祜。"
    ]
  },
  {
    "title": "瞻彼南山詩  其三",
    "author": "司馬光",
    "content": [
      "瞻彼南山，有杞有樅。",
      "維葉逢逢，君子之燕。",
      "管絲噰噰，奏鼓𪔳𪔳。",
      "自堂徂庭，上下肅雍。",
      "靡有不恭，君子萬年。",
      "令德高明，高明有融。"
    ]
  },
  {
    "title": "瞻彼南山詩  其四",
    "author": "司馬光",
    "content": [
      "赫赫明明，天命有嚴。",
      "命我祖考，九土是監。",
      "倭馯之東，蠻蜑之南。",
      "享獻有時，靡敢不詹。",
      "閟兹餘文，複閣巖巖。",
      "萬世是承，四方是瞻。"
    ]
  },
  {
    "title": "瞻彼南山詩  其五",
    "author": "司馬光",
    "content": [
      "帝曰卿士，左右之臣。",
      "四方無虞，矜爾之勤。",
      "式觀且遊，從予一人。",
      "于壼于閎，于堂于陳。",
      "金石之符，翰墨之珍。",
      "匪予汝夸，祖考之勲。"
    ]
  },
  {
    "title": "瞻彼南山詩  其六",
    "author": "司馬光",
    "content": [
      "多士庶尹，羣公百辟。",
      "拜手稽首，答揚休德。",
      "既醉既飽，慎思爾職。",
      "罔顧爾私，罔愛爾力。",
      "惇忠祗敕，永奉丕則。",
      "立民之極，載祀千億。"
    ]
  },
  {
    "title": "重別南給事",
    "author": "賈至",
    "content": [
      "謫宦三年尚未回，故人今日又重來。",
      "聞道崖州一千里，今朝須盡數千杯。"
    ]
  },
  {
    "title": "在巴南望郡南山呈樂天",
    "author": "白行簡",
    "content": [
      "臨江一嶂白雲間，紅綠層層錦繡班。",
      "不作巴南天外意，何殊昭應望驪山。"
    ]
  },
  {
