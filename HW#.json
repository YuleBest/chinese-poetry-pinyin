[
  {
    "title": "皇武 八",
    "author": "柳宗元",
    "content": [
      "王旅渾渾，是佚是怙。",
      "既獲敵師，若飢得餔。",
      "蔡兇伊窘，悉起來聚。",
      "左擣其虛，靡愆厥慮。"
    ]
  },
  {
    "title": "皇武 二",
    "author": "柳宗元",
    "content": [
      "皇咨于度，惟汝一德。",
      "曠誅四紀，其徯汝克。",
      "錫汝斧鉞，其往視師。",
      "師是蔡人，以宥以釐。"
    ]
  },
  {
    "title": "皇武 九",
    "author": "柳宗元",
    "content": [
      "載闢載袚，丞相是臨。",
      "弛其武刑，諭我德心。",
      "其危既安，有長如林。",
      "曾是讙譊，化爲謳吟。"
    ]
  },
  {
    "title": "皇武 六",
    "author": "柳宗元",
    "content": [
      "我斾我旗，于道于陌。",
      "訓于羣帥，拳勇來格。",
      "公曰徐之，無恃頟頟。",
      "式和爾容，惟義之宅。"
    ]
  },
  {
    "title": "回文  其一",
    "author": "無名氏",
    "content": [
      "紅窗小立低聲怨，永日春寒斗帳空。",
      "中酒落花飛絮亂，曉鶑啼破夢匆匆。"
    ]
  },
  {
    "title": "回文  其二",
    "author": "無名氏",
    "content": [
      "同誰更倚閑窗繡，落日紅扉小院深。",
      "東復西流分水嶺，恨兼愁續斷弦琴。"
    ]
  },
  {
    "title": "回文  其三",
    "author": "無名氏",
    "content": [
      "寒信風飄霜葉黄，冷燈殘月照空牀。",
      "看君寄憶回文錦，字字縈愁寫斷腸。"
    ]
  },
  {
    "title": "回文  其四",
    "author": "無名氏",
    "content": [
      "前堂畫燭殘凝淚，半夜清香舊惹衾。",
      "烟鎖竹枝寒宿鳥，水沈天色霽橫參。"
    ]
  },
  {
    "title": "回文  其五",
    "author": "無名氏",
    "content": [
      "娥翠斂時聞燕語，淚珠彈處見鴻歸。",
      "多情妾似風花亂，薄倖郎如露草晞。"
    ]
  },
  {
    "title": "回文  其一",
    "author": "無名氏",
    "content": [
      "春晚落花餘碧草，夜凉低月半枯桐。",
      "人隨遠雁邊城暮，雨映疏簾繡閣空。"
    ]
  },
  {
    "title": "回文  其二",
    "author": "無名氏",
    "content": [
      "紅手素絲千字錦，故人新曲九迴腸。",
      "風吹絮雪愁縈骨，淚灑縑書恨見郎。"
    ]
  },
  {
    "title": "回文  其三",
    "author": "無名氏",
    "content": [
      "羞看一首回文錦，錦似文君別恨深。",
      "頭白自吟悲賦客，斷腸愁是斷弦琴。"
    ]
  },
  {
    "title": "皇武 七",
    "author": "柳宗元",
    "content": [
      "進次于郾，彼昏卒狂。",
      "裒兇鞠頑，鋒蝟斧螗。",
      "赤子匍匐，厥父是亢。",
      "怒其萌芽，以悖太陽。"
    ]
  },
  {
    "title": "皇武 三",
    "author": "柳宗元",
    "content": [
      "度拜稽首，廟于元龜。",
      "既禡既類，于社是宜。",
      "金節煌煌，錫盾雕戈。",
      "犀甲熊旂，威命是荷。"
    ]
  },
  {
    "title": "皇武 四",
    "author": "柳宗元",
    "content": [
      "度拜稽首，出次于東。",
      "天子餞之，罍斝是崇。",
      "鼎臑俎胾，五獻百籩。",
      "凡百卿士，班以周旋。"
    ]
  },
  {
    "title": "皇武 十",
    "author": "柳宗元",
    "content": [
      "皇曰來歸，汝復相予。",
      "爵之成國，胙以夏區。",
      "度拜稽首，天子聖神。",
      "度拜稽首，皇祐下人。"
    ]
  },
  {
    "title": "皇武 十一",
    "author": "柳宗元",
    "content": [
      "淮夷既平，震是朔南。",
      "宜廟宜郊，以告德音。",
      "歸牛休馬，豐稼于埜。",
      "我武惟皇，永保無疆。"
    ]
  },
  {
    "title": "皇武 五",
    "author": "柳宗元",
    "content": [
      "既涉于滻，乃翼乃前。",
      "孰圖厥猶，其佐多賢。",
      "宛宛周道，于山于川。",
      "遠揚邇昭，陟降連連。"
    ]
  },
  {
    "title": "和吳𡼣巖韻",
    "author": "朱南杰",
    "content": [
      "春回筆底露潜機，爲怯高吟且遯肥。",
      "又見牛鞭春到日，羞披鶉結舊來衣。",
      "雪隨著處分單厚，梅不關人自密稀。",
      "歸計商量今始定，樂哉心事看雲飛。"
    ]
  },
  {
    "title": "皇武 一",
    "author": "柳宗元",
    "content": [
      "皇耆其武，于溵于淮。",
      "既巾乃車，環蔡具來。",
      "狡衆昏嚚，甚毒于酲。",
      "狂奔呌呶，以干大刑。"
    ]
  }
]