[
  {
    "title": "途中偶成寄幕下諸公",
    "author": "張嵲",
    "content": [
      "曠朗高天浄，蟬鳴江漢秋。",
      "川晴山歷歷，身遠意悠悠。",
      "落日慘行子，長風欺弊裘。",
      "郡樓今夜月，應從庾公游。"
    ]
  },
  {
    "title": "題趙鷗波高士圖",
    "author": "龔開",
    "content": [
      "雪氣侵人卧欲僵，苦勞明府到藜牀。",
      "主賓問答皆情語，何用閒名入薦章。"
    ]
  },
  {
    "title": "題趙鷗波高士圖",
    "author": "錢仲鼎",
    "content": [
      "在昔洛陽，雪深丈餘。",
      "士也高卧，來令尹車。",
      "今年吳淞，雪復何如。",
      "積素一色，鷗鷺有無。",
      "之子江臯，修亭是居。",
      "有琴有書，有酒有魚。",
      "賞靜獨眺，聊以自娛。",
      "挹茲清風，凜凜起予。",
      "此景此圖，再卷再舒。"
    ]
  }
]