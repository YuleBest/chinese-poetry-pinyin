[
  {
    "title": "冽井  其一",
    "author": "王柏",
    "content": [
      "冽彼井泉，蓮華斯名。",
      "有美一人，於焉載沈。",
      "夫也不二，昊天曰明。",
      "父之我愛，曷慰我心。"
    ]
  },
  {
    "title": "冽井  其二",
    "author": "王柏",
    "content": [
      "冽彼井泉，蓮華其號。",
      "有美一人，於焉是蹈。",
      "琴瑟既合，載言載笑。",
      "父母不允，中心悼悼。"
    ]
  },
  {
    "title": "冽井  其三",
    "author": "王柏",
    "content": [
      "有冽彼泉，弦歌之東。",
      "所謂伊人，宛在其中。",
      "我心既得，皇恤我躬。",
      "匪一死之，義之從容。"
    ]
  },
  {
    "title": "冽井  其四",
    "author": "王柏",
    "content": [
      "有冽彼泉，在弦歌內。",
      "所謂伊人，之死靡悔。",
      "人孰不死，我無昧昧。",
      "是心之存，炯千萬載。"
    ]
  },
  {
    "title": "六經  其一",
    "author": "陸游",
    "content": [
      "六經聖所傳，百代尊元龜。",
      "諄諄布方冊，一字不汝欺。",
      "抱書入家塾，自汝兒童時。",
      "老乃幸不驗，愚哉死何悲。"
    ]
  },
  {
    "title": "六經  其二",
    "author": "陸游",
    "content": [
      "秦人燔六經，非與經爲仇。",
      "方其勇决時，亦爲子孫謀。",
      "斂金鑄巨人，豈復畏鉏耰。",
      "千載惡名在，尚與黄河流。"
    ]
  }
]