[
  {
    "title": "太廟瑞芝頌",
    "author": "王炎",
    "content": [
      "宋紹天命，列聖重光。",
      "丕緒舄奕，施于無疆。",
      "少海日升，慶元五祀。",
      "淵默面南，格于天地。",
      "於穆清廟，玉芝呈瑞。",
      "蔓蔓其華，麗于丹楹。",
      "匪根斯殖，匪葩斯榮。",
      "和氣融液，不春而生。",
      "其瑞維何，祖宗咸喜。",
      "神孫致孝，孺慕無已。",
      "有開必先，産祥隤祉。",
      "其孝維何，神明可通。",
      "問安寢門，四輔翼從。",
      "洗爵爲壽，雍雍在宮。",
      "莫大之慶，朝野攸同。",
      "賚爾高年，曰予錫類。",
      "頒爵輔臣，曰汝予助。",
      "三宮豈樂，萬姓歌舞。",
      "維我高廟，中興集勳。",
      "神器所傳，藝祖之孫。",
      "重華之斷，壽康之仁。",
      "凝神沖漠，不俟倦勤。",
      "羣黎屬望，天啟元子。",
      "四聖揖遜，千古顓美。",
      "主鬯匪易，秉心肅莊。",
      "以奉重闈，媚於慈皇。",
      "崇德尚賢，心膂股肱。",
      "盡擯浮僞，慈皇是承。",
      "酬酢萬微，未明當依。",
      "不蔽不疑，慈皇是以。",
      "民附于仁，天鑒厥誠。",
      "對越在上，祖宗之靈。",
      "貺以瑞物，胙其德馨。",
      "昔在紹興，芝嘗再茁。",
      "仁皇英皇，二祖之室。",
      "曾孫篤之，克肖其德。",
      "受是珍符，寵綏四國。",
      "曷以祝之，萬壽無極。",
      "又曷申之，子孫千億。",
      "有德有瑞，隠顯合符。",
      "自今以始，史將婁書。",
      "皇德日新，勿替厥初。"
    ]
  },
  {
    "title": "同門人夜看花示盧魯山",
    "author": "徐積",
    "content": [
      "罷酒已半夜，重來慰幽花。",
      "可惜遭風雨，太半成泥沙。",
      "移坐環其叢，含香嚼其華。",
      "五人摘滿手，歸來千萬葩。"
    ]
  },
  {
    "title": "題美人",
    "author": "于鵠",
    "content": [
      "秦女窺人不解羞，攀花趁蝶出牆頭。",
      "胸前空帶宜男草，嫁得蕭郎愛遠遊。"
    ]
  },
  {
    "title": "題馬儒乂石門山居",
    "author": "顧非熊",
    "content": [
      "尋君石門隱，山近漸無青。",
      "鹿迹入柴戶，樹身穿草亭。",
      "雲低收藥徑，苔惹取泉瓶。",
      "此地客難到，夜琴誰共聽。"
    ]
  },
  {
    "title": "歎美人照鏡",
    "author": "陳述",
    "content": [
      "插花枝共動，含笑靨俱生。",
      "衫分兩處色，釧響一邊聲。",
      "就中還妒影，恐奪可憐名。"
    ]
  },
