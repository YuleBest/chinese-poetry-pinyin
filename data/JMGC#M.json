[
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 豫和",
    "author": "不詳",
    "content": [
      "至矣丕搆，烝哉太平。",
      "授犧膺籙，復禹繼明。",
      "草木仁化，鳧鷖頌聲。",
      "祀宗陳德，無媿斯誠。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 太和",
    "author": "不詳",
    "content": [
      "郊壇齋帝，禮樂祀天。",
      "丹青寰宇，宮徵山川。",
      "神祇畢降，行止重旋。",
      "融融穆穆，納祉洪延。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 肅和",
    "author": "不詳",
    "content": [
      "止奏潛聆，登儀宿囀。",
      "太玉躬奉，參鍾首奠。",
      "簠簋聿昇，犧牲遰薦。",
      "昭事顒若，存存以俔。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 雍和",
    "author": "不詳",
    "content": [
      "爛雲普洽，律風無外。",
      "千品其凝，九賓斯會。",
      "禋尊晉燭，純犧滌汰。",
      "玄覆攸廣，鴻休汪濊。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 壽和",
    "author": "不詳",
    "content": [
      "六變爰闋，八階載虔。",
      "祐我皇祚，於萬斯年。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 壽和",
    "author": "不詳",
    "content": [
      "於赫聖祖，龍飛晉陽。",
      "底定萬國，奄有四方。",
      "功格上下，道冠農黃。",
      "郊天配享，德合無疆。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 壽和",
    "author": "不詳",
    "content": [
      "崇崇泰畤，肅肅嚴禋。",
      "粢盛既潔，金石畢陳。",
      "上帝來享，介福爰臻。",
      "受釐合祉，寶祚維新。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 舒和",
    "author": "不詳",
    "content": [
      "祝史正辭，人神叶慶。",
      "福以德招，享以誠應。",
      "六變云備，百禮斯浹。",
      "祀事孔明，祚流萬葉。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 凱安",
    "author": "不詳",
    "content": [
      "馨香惟后德，明命光天保。",
      "肅和崇聖靈，陳信表皇道。",
      "玉鏚初蹈厲，金匏既靜好。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 豫和",
    "author": "不詳",
    "content": [
      "大號成命，思文配天。",
      "神光肸蠁，龍駕言旋。",
      "眇眇閶闔，昭昭上玄。",
      "俾昌而大，於斯萬年。"
    ]
  },
  {
    "title": "郊廟歌辭 明皇祀圜丘樂章 太和",
    "author": "不詳",
    "content": [
      "六成既闋，三薦云終。",
      "神心具醉，聖敬愈崇。",
      "受釐皇邸，回蹕帷宮。",
      "穰穰之福，永永無窮。"
    ]
  },
  {
    "title": "郊廟歌辭 明堂樂章 肅和",
    "author": "褚亮",
    "content": [
      "象天御宇，乘時布政。",
      "嚴配申虔，宗禋展敬。",
      "罇罍盈列，樹羽交映。",
      "玉幣通誠，祚隆皇聖。"
    ]
  },
  {
    "title": "郊廟歌辭 明堂樂章 雍和",
    "author": "褚亮",
    "content": [
      "八牖晨披，五精朝奠。",
      "霧凝璇篚，風清金縣。",
      "神滌備全，明粢豐衍。",
      "載絜彝俎，陳誠以薦。"
    ]
  },
  {
    "title": "郊廟歌辭 明堂樂章 舒和",
    "author": "褚亮",
    "content": [
      "御扆合宮承寶曆，席圖重館奉明靈。",
      "偃武修文九圍泰，沈烽靜柝八荒寧。"
    ]
  },
