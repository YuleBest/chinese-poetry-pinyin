[
  {
    "title": "郊廟歌辭  善勝舞",
    "author": "不詳",
    "content": [
      "聖祖累功，福鍾來裔。",
      "持羽執干，舞文不廢。"
    ]
  },
  {
    "title": "郊廟歌辭  肅順",
    "author": "不詳",
    "content": [
      "樂奏四順，福受萬年。",
      "神歸碧天，庭餘瑞煙。"
    ]
  },
