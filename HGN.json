[
  {
    "title": "懷廣南轉運陳學士狀元",
    "author": "釋希晝",
    "content": [
      "極望隨南斗，迢迢思欲迷。",
      "春生桂嶺外，人在海門西。",
      "殘日依山盡，長天向水低。",
      "遙知仙館夢，夜夜怯猿啼。"
    ]
  },
  {
    "title": "會廣南因上人",
    "author": "釋德洪",
    "content": [
      "我昔南游跨海還，夢中常憶海邊山。",
      "匡廬忽見山中客，果笑人間是夢間。"
    ],
    "meta": {
      "tags": [
        "庐山"
      ]
    }
  },
  {
    "title": "和歸鳥篇",
    "author": "李綱",
    "content": [
      "翼翼歸鳥，爰集于林。",
      "近萃芳郊，遠依煙岑。",
      "眷言顧之，實獲我心。",
      "叢木茂止，憇此繁陰。",
      "翼翼歸鳥，翩然翻飛。",
      "風髙天闊，去將疇依。",
      "雲路翺翔，倦翮思歸。",
      "矰繳孔多，無使患遺。",
      "翼翼歸鳥，撫翼徘徊。",
      "江湖緲茫，有懷故棲。",
      "顧儔嘯侣，鳴聲和諧。",
      "願言不獲，悵然傷懷。",
      "翼翼歸鳥，集于舊條。",
      "一枝已多，豈俟髙標。",
      "歛翰息影，好音交交。",
      "願言終此，以休永勞。"
    ]
  }
]